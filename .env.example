# ─── AI 赛事分析 ─────────────────────────────────────────────
# MiniMax API Key（优先使用）。配置后 AI 分析走 MiniMax，未配置回退 Qwen，再回退本地分析
MINIMAX_API_KEY=

# Qwen API Key (通义千问) — MiniMax 未配置时的备选
# 获取方式：https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# API-Football Key (可选，用于抓取真实数据)
# 获取方式：https://www.api-football.com/
API_FOOTBALL_KEY=

# ─── MySQL（保存预测结果）────────────────────────────────────
# 未配置时应用正常运行，仅跳过预测结果持久化
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
