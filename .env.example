# ─── AI 赛事分析 / Agent 报告 ───────────────────────────────
# Qwen OpenAI-compatible API
QWEN_API_KEY=
QWEN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
QWEN_MODEL=qwen3.7-plus

# football-data.org API Token (用于拉取真实比赛结果)
# 获取方式：https://www.football-data.org/client/
FOOTBALL_DATA_API_KEY=

# ─── MySQL（保存预测结果）────────────────────────────────────
# 未配置时应用正常运行，仅跳过预测结果持久化
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
